PORT=4000

# Gmail SMTP. SMTP_PASS must be a Google App Password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-google-app-password

# Usually keep MAIL_FROM the same mailbox as SMTP_USER.
MAIL_FROM="Your Name <your-gmail@gmail.com>"
MAIL_SUBJECT=EU RATE BAO GIA


# 120000 ms = 2 minutes. Change to 10000 for a quick local test.
SEND_INTERVAL_MS=120000

# false = first email is sent after SEND_INTERVAL_MS.
# true = first email is sent immediately, then each next email waits SEND_INTERVAL_MS.
SEND_FIRST_IMMEDIATELY=true
